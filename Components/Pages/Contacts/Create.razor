@page "/contacts/create"
@using ContactBook.Data
@using ContactBook.Models
@inject AppDbContext DbContext
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.Medium" Class="d-flex flex-column align-center mt-20">
    
    <EditForm Model="_contact" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <MudCard Class="pr-6 pb-6 pl-6" Style="min-width:450px;">
            <MudCardContent>
                
                <MudPaper Elevation="1" Class="d-inline-block rounded-circle mb-5">
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="GoBack" />
                </MudPaper>

                <MudText Typo="Typo.h5" Class="mb-4">
                    Add Contact
                </MudText>

                <MudTextField T="string"
                              Label="First Name"
                              @bind-Value="_contact.FirstName"
                              For="@(() => _contact.FirstName)"
                              Immediate="true"
                              Variant="Variant.Outlined"/>

                <MudTextField T="string"
                              Label="Last Name"
                              Class="mt-4"
                              @bind-Value="_contact.LastName"
                              For="@(() => _contact.LastName)"
                              Immediate="true"
                              Variant="Variant.Outlined"/>

                <MudTextField T="string"
                              Label="Email"
                              Class="mt-4"
                              @bind-Value="_contact.Email"
                              For="@(() => _contact.Email)"
                              Immediate="true"
                              Variant="Variant.Outlined"/>

                <MudTextField T="string"
                              Label="Phone Number"
                              Class="mt-4"
                              @bind-Value="_contact.PhoneNumber"
                              For="@(() => _contact.PhoneNumber)"
                              Immediate="true"
                              Variant="Variant.Outlined"/>

                <MudTextField T="string"
                              Label="Company"
                              Class="mt-4"
                              @bind-Value="_contact.Company"
                              For="@(() => _contact.Company)"
                              Immediate="true"
                              Variant="Variant.Outlined"/>

            </MudCardContent>

            <MudCardActions>
                <MudSpacer />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary">
                    Save Contact
                </MudButton>

            </MudCardActions>
        </MudCard>
    </EditForm>
    
</MudContainer>

@code {
    private Contact _contact = new();

    private async Task HandleSubmit()
    {
        DbContext.Contacts.Add(_contact);
        await DbContext.SaveChangesAsync();
        
        Snackbar.Add(
            "Contact saved successfully",
            Severity.Success);

        _contact = new Contact();
    }
    
    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }
}